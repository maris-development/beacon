# Copy to .env and adjust. docker-compose and the harness both read these.

# ---- Scale -----------------------------------------------------------------
# Dataset size preset used by data-gen/generate.py: small | medium | large
# small  ~ 100 MB parquet (wiring/iteration)
# medium ~ 2 GB parquet   (the real run)
# large  ~ 10 GB+ parquet (stress)
BENCH_SCALE=small

# ---- Host ports ------------------------------------------------------------
BEACON_HOST_PORT=5001
POSTGRES_HOST_PORT=5432
TRINO_HOST_PORT=8080
PRESTO_HOST_PORT=8090
DUCKDB_HOST_PORT=8500

# ---- Fairness: equal resource caps applied to every engine container -------
# Keep these identical across engines so the comparison is apples-to-apples.
ENGINE_CPUS=4
ENGINE_MEM=8g

# ---- Image tags (pin for reproducibility) ----------------------------------
# Beacon 1.7.x line. Default is the published 1.7.0 image (newest release tag on ghcr;
# `latest` is stale at v1.5.0, and the v2.x nightlies require a BEACON_TOKEN).
# 1.7.1 is the current source release and shares the same query engine — when a 1.7.1
# image is published, just swap the tag below, or build one locally from the 1.7.1 tree:
#     docker build -t beacon:1.7.1 .      # then: BEACON_IMAGE=beacon:1.7.1
# The harness records the running engine's actual version via beacon_version().
BEACON_IMAGE=ghcr.io/maris-development/beacon:v.1.7.0
POSTGRES_IMAGE=postgres:16
HIVE_METASTORE_IMAGE=apache/hive:4.0.0
TRINO_IMAGE=trinodb/trino:457
PRESTO_IMAGE=prestodb/presto:0.289
DUCKDB_IMAGE=python:3.12-slim
DUCKDB_MEMORY=8GB

# ---- Postgres (subject under test) -----------------------------------------
POSTGRES_USER=bench
POSTGRES_PASSWORD=bench
POSTGRES_DB=bench

# ---- Beacon tuning ---------------------------------------------------------
BEACON_VM_MEMORY_SIZE=4096
BEACON_WORKER_THREADS=4
